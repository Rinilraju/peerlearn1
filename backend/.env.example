PORT=5000
DB_USER=postgres
DB_HOST=localhost
DB_NAME=peerlearn
DB_PASSWORD=1234
DB_PORT=5432
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Frontend origin used for Stripe success/cancel redirects
CLIENT_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx

# Keep this true to bypass gateway and directly enroll on "Enroll Now".
SIMULATE_PAYMENTS=true

# AI-powered tutor verification quiz generation.
# AI-only mode is enabled by default in code.
# Keep QUIZ_REQUIRE_AI=true to block non-AI fallback.
QUIZ_REQUIRE_AI=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
