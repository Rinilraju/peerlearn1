VITE_API_URL=http://localhost:5000

# Configure ICE servers for WebRTC internet connectivity.
# Include at least one TURN server for reliable audio/video across NAT/firewalls.
# Example:
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.yourdomain.com:3478","username":"user","credential":"pass"}]
VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]
